# Supabase project settings (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App runtime — Supabase: Connect → Database → URI → pooler **Transaction** (port 6543).
# IPv4-friendly; use in lib/db/index.ts (serverless / Vercel).
DATABASE_URL=

# Migrations & Drizzle Kit — Connect → Database → URI → pooler **Session** (port 5432).
# Same pooler host as Transaction, different mode/port. Do not use Direct here: that endpoint
# is often IPv6-only and will not connect from a typical IPv4 Mac/network.
DATABASE_MIGRATE_URL=
