# Supabase project settings (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App runtime — Connect → Database → URI → pooler **Transaction** (port 6543).
# User is often postgres.<project-ref>, host aws-*-<region>.pooler.supabase.com (not db.*.supabase.co).
DATABASE_URL=

# Migrations & Drizzle Kit — same pooler host, **Session** mode (port 5432).
# Required for pnpm db:migrate. Direct db.*.supabase.co is IPv6-only on many projects.
DATABASE_MIGRATE_URL=

# Server-only secret for hashed_display_id (Authentication → never expose to client)
SIGN_DISPLAY_ID_SECRET=
