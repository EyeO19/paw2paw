# Supabase project settings (Dashboard → Project Settings → API)
# Project URL only — e.g. https://<project-ref>.supabase.co (no /rest/v1/ suffix).
# Do not copy the REST API URL from the API panel; use the base project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key from the same API page — safe in the browser bundle; RLS still applies
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App runtime — Dashboard → Connect → Database → URI → pooler **Transaction** (port 6543).
# User is often postgres.<project-ref>; host aws-*-<region>.pooler.supabase.com (not db.*.supabase.co).
# Used by lib/db/index.ts if server-side Drizzle is enabled; keep server-only on Vercel.
DATABASE_URL=

# Migrations & Drizzle Kit — same pooler host, **Session** mode (port 5432).
# Required for pnpm db:migrate and pnpm db:studio. Direct db.*.supabase.co is IPv6-only on many networks.
DATABASE_MIGRATE_URL=

# Server-only — random secret for hashed_display_id (openssl rand -base64 32). Never expose to client.
SIGN_DISPLAY_ID_SECRET=
